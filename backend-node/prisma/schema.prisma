// Este arquivo define a estrutura do banco de dados PostgreSQL.
// Após configurar o .env, rode: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── USUÁRIOS ──────────────────────────────────────────────
model Usuario {
  id      Int         @id @default(autoincrement())
  nome  String
  email   String      @unique
  senha   String  
  criadoEm  DateTime  @default(now())
  role    Role        @default(USER)
}

enum Role {
  ADMIN
  USER
}

// ── CATEGORIAS (Os Subs) ──────────────────────────────────
model Categoria {
  id        Int           @id @default(autoincrement())
  nome      String 
  tipo      TipoCategoria
  
  jogadores Jogador[]
  partidas  Partida[]
}

enum TipoCategoria {
  INICIACAO
  BASE
}

// ── COMPETIÇÕES (Dropdown) ───────────────────
model Competicao {
  id        Int       @id @default(autoincrement())
  nome      String
  ano       Int 
  
  partidas  Partida[]
}

// ── TIMES (Para Mandante e Visitante) ─────────────────────
model Time {
  id                 Int       @id @default(autoincrement())
  nome               String
  escudo             String?
  
  partidas_mandante  Partida[] @relation("Mandante")
  partidas_visitante Partida[] @relation("Visitante")
  eventos            Evento[]
}

// ── JOGADORES (O Elenco do Ocian) ─────────────────────────
model Jogador {
  id           Int       @id @default(autoincrement())
  nome         String
  cpf          String    @unique
  dtNasc       DateTime  @db.Date
  numCamisa    Int?      
  posicao      String
  perfil_ml    String?
  
  categoria_id Int 
  categoria    Categoria @relation(fields: [categoria_id], references: [id])
  
  eventos      Evento[]
}

// ── PARTIDAS ──────────────────────────────────────────────
model Partida {
  id             Int           @id @default(autoincrement())
  
  // Relação com os Times
  mandante_id    Int
  mandante       Time          @relation("Mandante", fields: [mandante_id], references: [id])
  
  visitante_id   Int
  visitante      Time          @relation("Visitante", fields: [visitante_id], references: [id])
  
  // Placar direto (para leitura rápida)
  gols_mandante  Int           @default(0)
  gols_visitante Int           @default(0)
  
  // Dados do Jogo
  data           DateTime      @default(now())
  horario        String?       // "19:30"
  local          String?
  emCasa         Boolean       @default(true)
  status         StatusPartida @default(AGENDADA)
  
  // Relação com a Categoria (Sub) e Competição
  categoria_id   Int?
  categoria      Categoria?    @relation(fields: [categoria_id], references: [id])
  
  competicao_id  Int?
  competicao     Competicao?   @relation(fields: [competicao_id], references: [id])
  
  // Detalhes minuto a minuto
  eventos        Evento[]
}

enum StatusPartida {
  AGENDADA
  AO_VIVO
  FINALIZADA
}

// ── EVENTOS (O Scout / Event Sourcing para a IA) ──────────
model Evento {
  id         Int        @id @default(autoincrement())
  partida_id Int
  partida    Partida    @relation(fields: [partida_id], references: [id])
  
  tipo       TipoEvento
  minuto     Int

  // Qual time fez a ação? (Obrigatório)
  time_id    Int
  time       Time       @relation(fields: [time_id], references: [id])
  
  // Qual jogador do Ocian fez a ação? (Opcional, pois pode ser um evento do adversário)
  jogador_id Int?
  jogador    Jogador?   @relation(fields: [jogador_id], references: [id])
}

enum TipoEvento {
  GOL
  ASSISTENCIA
  DESARME
  CARTAO_AMARELO
  CARTAO_VERMELHO
  FALTA
}